# RxMonitor Environment Configuration
# Copy this file to .env and fill in your values

# Server
PORT=4000

# Base URL (used for verification emails and agent install script)
BASE_URL=https://server.goroomz.in

# JWT Secret — generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=change-this-to-a-random-string

# Google OAuth (optional — for Google Sign-In)
# GOOGLE_CLIENT_ID=xxxxxxxxxxxx.apps.googleusercontent.com

# SMTP Configuration (optional — overrides admin panel settings)
# Used for sending verification emails to users during signup.
# If not configured, verification links are logged to the console instead.
# Environment variables take priority over admin panel SMTP settings.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
