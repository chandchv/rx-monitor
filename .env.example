# RxMonitor Environment Configuration
# Copy this file to .env and fill in your values

# Server
PORT=4000

# Base URL (used for verification emails and agent install script)
BASE_URL=https://server.goroomz.in

# JWT Secret — generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=change-this-to-a-random-string

# Google OAuth (optional — for Google Sign-In)
# GOOGLE_CLIENT_ID=xxxxxxxxxxxx.apps.googleusercontent.com
